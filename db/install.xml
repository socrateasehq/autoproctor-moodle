<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="mod/quiz/accessrule/autoproctor/db" VERSION="20240301" COMMENT="XMLDB file for AutoProctor plugin">
    <TABLES>
        <TABLE NAME="quizaccess_autoproctor_sessions" COMMENT="Stores proctoring session data">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="quiz_attempt_id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="session_id" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="pending" SEQUENCE="false"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="quiz_attempt_id" TYPE="foreign" FIELDS="quiz_attempt_id" REFTABLE="quiz_attempts" REFFIELDS="id"/>
            </KEYS>
        </TABLE>
    </TABLES>
</XMLDB> 